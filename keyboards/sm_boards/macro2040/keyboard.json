{
  "keyboard_name": "macro2040",
  "manufacturer": "SM Boards",
  "url": "https://github.com/sjb-dev/MacroPad",
  "maintainer": "sjb-dev",
  "processor": "RP2040",
  "bootloader": "rp2040",
  "usb": {
    "vid": "0x534D",
    "pid": "0x4D32",
    "device_version": "1.0.0"
  },
  "features": {
    "bootmagic": true,
    "mousekey": true,
    "extrakey": true,
    "encoder": true
  },
  "matrix_pins": {
    "cols": ["GP1", "GP2"],
    "rows": ["GP8", "GP9", "GP10", "GP11"]
  },
  "diode_direction": "COL2ROW",
  "encoder": {
    "rotary": [
      {
        "pin_a": "GP23",
        "pin_b": "GP22"
      }
    ]
  },
  "ws2812": {
    "pin": "GP17",
    "driver": "vendor"
  },
  "rgb_matrix": {
    "driver": "ws2812",
    "max_brightness": 128,
    "default": {
      "animation": "rainbow_moving_chevron"
    },
    "animations": {
      "alphas_mods": true,
      "gradient_up_down": true,
      "gradient_left_right": true,
      "breathing": true,
      "band_sat": true,
      "band_val": true,
      "band_pinwheel_sat": true,
      "band_pinwheel_val": true,
      "band_spiral_sat": true,
      "band_spiral_val": true,
      "cycle_all": true,
      "cycle_left_right": true,
      "cycle_up_down": true,
      "cycle_out_in": true,
      "cycle_out_in_dual": true,
      "rainbow_moving_chevron": true,
      "cycle_pinwheel": true,
      "cycle_spiral": true,
      "dual_beacon": true,
      "rainbow_beacon": true,
      "rainbow_pinwheels": true,
      "raindrops": true,
      "jellybean_raindrops": true,
      "hue_breathing": true,
      "hue_pendulum": true,
      "hue_wave": true,
      "pixel_rain": true,
      "pixel_flow": true,
      "pixel_fractal": true,
      "typing_heatmap": true,
      "digital_rain": true,
      "solid_reactive_simple": true,
      "solid_reactive": true,
      "solid_reactive_wide": true,
      "solid_reactive_multiwide": true,
      "solid_reactive_cross": true,
      "solid_reactive_multicross": true,
      "solid_reactive_nexus": true,
      "solid_reactive_multinexus": true,
      "splash": true,
      "multisplash": true,
      "solid_splash": true,
      "solid_multisplash": true
    },
    "layout": [
      {"x": 0, "y": 16, "flags": 4},
      {"matrix": [0, 0], "x": 37, "y": 0, "flags": 4},
      {"matrix": [0, 1], "x": 37, "y": 32, "flags": 4},
      {"matrix": [1, 0], "x": 75, "y": 0, "flags": 4},
      {"matrix": [1, 1], "x": 75, "y": 32, "flags": 4},
      {"matrix": [2, 0], "x": 112, "y": 0, "flags": 4},
      {"matrix": [2, 1], "x": 112, "y": 32, "flags": 4}
    ]
  },
  "layouts": {
    "LAYOUT": {
      "layout": [
        {"matrix": [0, 0], "x": 1,    "y": 0},
        {"matrix": [1, 0], "x": 2,    "y": 0},
        {"matrix": [2, 0], "x": 3,    "y": 0},
        {"matrix": [0, 1], "x": 1,    "y": 1},
        {"matrix": [1, 1], "x": 2,    "y": 1},
        {"matrix": [2, 1], "x": 3,    "y": 1},
        {"matrix": [3, 1], "x": 0,    "y": 1.5, "w": 0.75, "h": 0.75}
      ]
    }
  }
}
